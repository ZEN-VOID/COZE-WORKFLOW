{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLMNodeConfig",
  "type": "object",
  "required": ["config", "tools", "sp", "up"],
  "properties": {
    "config": {
      "type": "object",
      "required": ["model", "temperature", "top_p", "max_completion_tokens", "thinking"],
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "top_p": { "type": "number" },
        "max_completion_tokens": { "type": "integer" },
        "thinking": { "type": "string" },
        "timeout_seconds": { "type": "integer" },
        "retry_count": { "type": "integer" },
        "fallback_model": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "object" }
    },
    "sp": { "type": "string" },
    "up": { "type": "string" }
  }
}
