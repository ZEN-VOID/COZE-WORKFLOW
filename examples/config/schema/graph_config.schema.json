{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GraphConfig",
  "type": "object",
  "required": ["name", "entry_point", "nodes", "edges"],
  "properties": {
    "name": { "type": "string" },
    "entry_point": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "llm_cfg": { "type": "string" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" }
        }
      }
    }
  }
}
